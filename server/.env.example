# ─── DATABASE ─────────────────────────────────────────────────
# PostgreSQL connection string
# Local:   postgresql://USER:PASSWORD@localhost:5432/auditpath
# Railway: paste your Railway DATABASE_URL here
DATABASE_URL="postgresql://postgres:password@localhost:5432/auditpath"

# ─── AUTH ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_this_to_a_long_random_string_before_deploying"
JWT_EXPIRES_IN="7d"

# ─── SERVER ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CLIENT (for CORS) ────────────────────────────────────────
CLIENT_URL="http://localhost:3000"
